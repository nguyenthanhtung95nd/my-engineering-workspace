{
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Bash(git:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(printenv:*)",
      "Bash(env:*)"
    ]
  }
}
